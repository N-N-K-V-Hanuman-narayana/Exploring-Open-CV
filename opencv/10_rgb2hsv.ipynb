   "source": [
    "# Program to convert RGB image into HSV color space\n",
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "img=cv2.imread(\"mani2.jpg\")\n",
    "hsv=cv2.cvtColor(img,cv2.COLOR_BGR2HSV)\n",
    "plt.imshow(hsv)\n",
    "plt.show()"
   ]
