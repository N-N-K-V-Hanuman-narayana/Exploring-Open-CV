   "source": [
    "import cv2\n",
    "from matplotlib import pyplot as plt\n",
    "\n",
    "img = cv2.imread(\"mani2.jpg\")\n",
    "img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n",
    "\n",
    "alpha = 1.6\n",
    "beta = 0.8\n",
    "result = cv2.convertScaleAbs(img, alpha=alpha, beta=beta)\n",
    "plt.imshow(img)\n",
    "plt.subplot(1,2,2)\n",
    "plt.imshow(result)\n",
    "\n",
    "plt.show()"
   ]
  },
